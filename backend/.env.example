FLASK_ENV=development
FLASK_DEBUG=True
JWT_SECRET_KEY=CAMBIAR_ESTA_CLAVE_POR_UNA_DE_MINIMO_32_CARACTERES_2026
JWT_ACCESS_TOKEN_HOURS=72

LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_ATTEMPT_WINDOW_MINUTES=15

AUDIT_LOG_RETENTION_DAYS=180
AUDIT_RETENTION_CLEANUP_INTERVAL_MINUTES=60

# Puerto del servidor unificado (en Render se inyecta automaticamente PORT)
PORT=5001

# Ruta SQLite (en Render usar disco persistente, ejemplo: /var/data/celupro.db)
CELUPRO_DB_PATH=./database/celupro.db

# Opcional: desactivar workers en entornos efimeros de pruebas
# CELUPRO_DISABLE_BACKGROUND_WORKERS=true
